  "keyFeatures": [
    "Direct PDF translation using vision-capable multimodal models (no OCR needed)",
    "Smart document handling for PDFs, Word documents, and text files",
    "Intelligent translation algorithms with context-aware text splitting",
    "Support for OpenAI, Anthropic, Google, and local Ollama models",
    "Glossary support for consistent terminology across documents",
    "Checkpoint and resume for large document translations",
    "Cost tracking and estimation before translation",
    "Flexible reasoning effort levels to balance quality and cost"
  ],
  "publicApiSurface": [
    "tinbox translate - Main translation command",
    "tinbox doctor - Diagnostic tool for setup validation",
    "translate_document() - Core translation function",
    "load_document() - Document loading and processing",
    "estimate_cost() - Cost estimation utility",
    "TranslationConfig - Configuration model",
    "DocumentContent - Document representation",
    "ModelInterface - LLM interface protocol",
    "CheckpointManager - Resume translation support",
    "GlossaryManager - Terminology management"
  ]
